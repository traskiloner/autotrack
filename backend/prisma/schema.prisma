generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique @db.VarChar(50)
  email          String          @unique @db.VarChar(100)
  password_hash  String          @db.VarChar(255)
  role           String          @default("user") @db.VarChar(20)
  created_at     DateTime        @default(now()) @db.Timestamp()
  is_active      Boolean         @default(true)
  login_count    Int             @default(0)
  last_login_ip  String?         @db.VarChar(45)
  last_login_at  DateTime?       @db.Timestamp()
  cars           Car[]
  inventory      InventoryPart[]
  shared_cars    CarShare[]

  @@map("users")
}


model Car {
  id            Int                @id @default(autoincrement())
  user_id       Int?
  brand         String             @db.VarChar(50)
  model         String             @db.VarChar(50)
  year          Int
  license_plate String             @db.VarChar(20)
  color         String?            @db.VarChar(30)
  mileage       Int?               @default(0)
  engine_code   String?            @db.VarChar(50)
  vin           String?            @db.VarChar(50)
  tire_size     String?            @db.VarChar(50)
  oil_type      String?            @db.VarChar(50)
  created_at    DateTime?          @default(now()) @db.Timestamp()
  user          User?              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  maintenances  Maintenance[]
  alerts        MaintenanceAlert[]
  fuel_logs     FuelLog[]
  shares        CarShare[]

  @@map("cars")
}

model Maintenance {
  id            Int       @id @default(autoincrement())
  car_id        Int?
  description   String    @db.Text
  mileage       Int
  cost          Decimal?  @default(0.00) @db.Decimal(10, 2)
  date          DateTime  @db.Date
  category      String?   @default("Otros") @db.VarChar(50)
  document_path String?   @db.VarChar(255)
  checklist     Json?     @default("[]") @db.JsonB
  created_at    DateTime? @default(now()) @db.Timestamp()
  car           Car?      @relation(fields: [car_id], references: [id], onDelete: Cascade)
  parts         Part[]

  @@map("maintenances")
}

model InventoryPart {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  name        String    @db.VarChar(100)
  brand       String?   @db.VarChar(50)
  part_number String?   @db.VarChar(50)
  price       Decimal?  @default(0.00) @db.Decimal(10, 2)
  stock       Int?      @default(0)
  created_at  DateTime? @default(now()) @db.Timestamp()
  user        User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parts       Part[]

  @@map("inventory_parts")
}

model Part {
  id                Int            @id @default(autoincrement())
  maintenance_id    Int?
  part_name         String         @db.VarChar(100)
  brand             String?        @db.VarChar(50)
  part_number       String?        @db.VarChar(50)
  quantity          Int?           @default(1)
  price             Decimal?       @default(0.00) @db.Decimal(10, 2)
  inventory_part_id Int?
  created_at        DateTime?      @default(now()) @db.Timestamp()
  maintenance       Maintenance?   @relation(fields: [maintenance_id], references: [id], onDelete: Cascade)
  inventory_part    InventoryPart? @relation(fields: [inventory_part_id], references: [id], onDelete: SetNull)

  @@map("parts")
}

model MaintenanceAlert {
  id             Int       @id @default(autoincrement())
  car_id         Int?
  description    String    @db.VarChar(255)
  target_date    DateTime? @db.Date
  target_mileage Int?
  is_completed   Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.Timestamp()
  car            Car?      @relation(fields: [car_id], references: [id], onDelete: Cascade)

  @@map("maintenance_alerts")
}

model FuelLog {
  id              Int       @id @default(autoincrement())
  car_id          Int
  date            DateTime  @db.Date
  mileage         Int
  liters          Decimal   @db.Decimal(10, 2)
  price_per_liter Decimal   @db.Decimal(10, 2)
  total_cost      Decimal   @db.Decimal(10, 2)
  is_full_tank    Boolean   @default(true)
  created_at      DateTime? @default(now()) @db.Timestamp()
  car             Car       @relation(fields: [car_id], references: [id], onDelete: Cascade)

  @@map("fuel_logs")
}

model CarShare {
  id         Int      @id @default(autoincrement())
  car_id     Int
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamp()
  
  car  Car  @relation(fields: [car_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([car_id, user_id])
  @@map("car_shares")
}

